# ── Dependencies & build artifacts ──────────────────────────────────
node_modules/
dist/
.turbo/
*.tsbuildinfo
.wrangler/
coverage/
*.log
*.tgz
examples/benchmarks/report-*.md
docs/.vitepress/dist/
docs/.vitepress/cache/

# ── Local caches (benchmarks, agent scratch) ────────────────────────
.tmp/
tmp/
.cache/
