# EditorConfig — https://editorconfig.org
# Keeps indentation / EOL / trailing whitespace consistent across editors
# (VS Code, JetBrains, vim, emacs, Sublime, ...). Most editors pick this
# up automatically; for VS Code install the "EditorConfig for VS Code"
# extension.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
# Two trailing spaces in Markdown = explicit line break — preserve them.
trim_trailing_whitespace = false
