# wasmagent-js environment variables — copy to .env.local for local dev
#
# Production / Cloudflare deploy: set these via `wrangler secret put <NAME>`
# or the platform's secret manager. Never commit the populated values.
#
# Required vs optional:
#   - You only need keys for the LLM providers you actually plan to call.
#   - Most examples / benchmarks default to no-op when the relevant key
#     is missing (skipping that provider's tests).

# ── Anthropic (Claude) ───────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # optional override

# ── OpenAI ───────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ── DeepSeek ─────────────────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...

# ── 火山引擎 Volcengine Ark (Doubao / 豆包) ───────────────────────────
# Get your key at: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# DOUBAO_API_KEY=
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3   # optional override

# ── Moonshot (Kimi) ──────────────────────────────────────────────────
# Get your key at: https://platform.moonshot.cn/console/api-keys
# MOONSHOT_API_KEY=sk-...

# ── 智谱 ZhipuAI (GLM) ────────────────────────────────────────────────
# Get your key at: https://open.bigmodel.cn/usercenter/apikeys
# ZHIPU_API_KEY=

# ── MiniMax ──────────────────────────────────────────────────────────
# Get your key at: https://platform.minimaxi.com/user-center/basic-information/interface-key
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=

# ── 阿里 DashScope (Qwen) ─────────────────────────────────────────────
# Get your key at: https://bailian.console.aliyun.com/?apiKey=1
# DASHSCOPE_API_KEY=

# ── Tavily (web search tool) ─────────────────────────────────────────
# Used by examples/tool-search-rag; optional.
# Get your key at: https://app.tavily.com/home
# TAVILY_API_KEY=

# ── Optional WasmAgent dev / runtime flags ───────────────────────────
# Skip the kernel-wasmtime javy autoinstall (CI / restricted envs)
# WASMAGENT_SKIP_POSTINSTALL=1
# Force local @wasmagent/* resolution (set automatically by bun workspaces)
# WASMAGENT_DEV_LOCAL=1
# Override the local model cache directory (kernel-remote / model-local)
# WASMAGENT_MODEL_DIR=~/.cache/wasmagent/models
# Mirror used by the local model downloader
# WASMAGENT_MODEL_MIRROR=https://hf-mirror.com

# ── OTel semconv opt-in ──────────────────────────────────────────────
# Set to "http/dup" or "http" if exporting to a collector that requires
# the new GenAI semantic conventions.
# OTEL_SEMCONV_STABILITY_OPT_IN=http
