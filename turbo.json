{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"],
      "outputs": []
    },
    "@wasmagent/kernel-pyodide#test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "lint": {
      "inputs": ["src/**/*.ts"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tsconfig.json"],
      "outputs": []
    },
    "clean": {
      "cache": false,
      "outputs": ["dist/**", ".turbo/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
