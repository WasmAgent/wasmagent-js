{
  "name": "@wasmagent/aisdk",
  "version": "1.0.5",
  "description": "Drop wasmagent sandbox kernels into the Vercel AI SDK as a `tool()` — edge-safe code execution with one capability manifest, no E2B / OS sandbox needed",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@wasmagent/core": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^4.0.0 || ^5.0.0 || ^6.0.0",
    "zod": "^3.22.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": false
    },
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "ai": "^4.0.0",
    "typescript": "^5.7.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "wasmagent",
    "wasm",
    "agent",
    "portable",
    "sandbox",
    "executor",
    "ai",
    "llm",
    "typescript"
  ],
  "wasmagent": {
    "tier": "tier-1",
    "stability": "alpha"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WasmAgent/wasmagent-js.git",
    "directory": "packages/aisdk"
  },
  "homepage": "https://github.com/WasmAgent/wasmagent-js/tree/main/packages/aisdk#readme",
  "bugs": {
    "url": "https://github.com/WasmAgent/wasmagent-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "wasmagent contributors"
}
