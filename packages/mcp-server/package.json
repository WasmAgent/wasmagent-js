{
  "name": "@wasmagent/mcp-server",
  "version": "1.1.3",
  "mcpName": "io.github.telleroutlook/mcp-server",
  "description": "Expose any wasmagent agent as a Model Context Protocol (MCP) server — sync tools/call + 2025-11-25 Tasks for long-running agent work",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wasmagent-mcp-server": "./dist/stdio.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./stdio": {
      "import": "./dist/stdio.js",
      "types": "./dist/stdio.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@wasmagent/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "wasmagent",
    "wasm",
    "agent",
    "portable",
    "sandbox",
    "executor",
    "ai",
    "llm",
    "typescript"
  ],
  "wasmagent": {
    "tier": "tier-0",
    "stability": "stable"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WasmAgent/wasmagent-js.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/WasmAgent/wasmagent-js/tree/main/packages/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/WasmAgent/wasmagent-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "wasmagent contributors"
}
