{
  "name": "@wasmagent/aep",
  "version": "1.16.0",
  "description": "Agent Evidence Protocol — runtime action evidence and run provenance types for WasmAgent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist .turbo",
    "schema:export": "bun run scripts/export-json-schema.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "wasmagent",
    "aep",
    "evidence",
    "provenance",
    "compliance"
  ],
  "wasmagent": {
    "tier": "tier-1",
    "stability": "beta"
  },
  "homepage": "https://github.com/WasmAgent/wasmagent-js/tree/main/packages/aep#readme",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/WasmAgent/wasmagent-js.git",
    "directory": "packages/aep"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "schemas",
    "examples",
    "README.md",
    "LICENSE"
  ]
}
