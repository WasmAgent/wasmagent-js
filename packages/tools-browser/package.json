{
  "name": "@wasmagent/tools-browser",
  "version": "1.0.7",
  "description": "Browser automation tools for wasmagent — Playwright + CDP-bridge for navigate/click/fill/screenshot/extract",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "dependencies": {
    "@wasmagent/core": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "playwright": "^1.40.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "wasmagent",
    "wasm",
    "agent",
    "portable",
    "sandbox",
    "executor",
    "ai",
    "llm",
    "typescript"
  ],
  "wasmagent": {
    "tier": "tier-2",
    "stability": "stable"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WasmAgent/wasmagent-js.git",
    "directory": "packages/tools-browser"
  },
  "homepage": "https://github.com/WasmAgent/wasmagent-js/tree/main/packages/tools-browser#readme",
  "bugs": {
    "url": "https://github.com/WasmAgent/wasmagent-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "wasmagent contributors"
}
