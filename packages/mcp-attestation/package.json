{
  "name": "@wasmagent/mcp-attestation",
  "version": "0.1.0",
  "description": "MCP capability attestation for WasmAgent servers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
