    "@anthropic-ai/sdk": "^0.55.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telleroutlook/agentkit-js.git",
    "directory": "packages/model-anthropic"
  },
  "homepage": "https://github.com/telleroutlook/agentkit-js/tree/main/packages/model-anthropic#readme",
  "bugs": {
    "url": "https://github.com/telleroutlook/agentkit-js/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agentkit",
    "agent",
    "ai",
    "llm"
