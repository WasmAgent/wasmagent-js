{
  "name": "@agentkit-js/kernel-wasmtime",
  "version": "0.1.0",
  "description": "WasmtimeKernel — true WASM sandbox for agentkit-js via Javy (QuickJS→WASM) + Node's native WebAssembly API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentkit-js/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["webassembly", "wasm", "wasi", "javy", "sandbox", "agentkit"],
  "license": "Apache-2.0"
}
