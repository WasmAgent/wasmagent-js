{
  "name": "@wasmagent/ui-cards",
  "version": "1.0.3",
  "description": "Card block parser for wasmagent — extracts ```card:* fenced blocks from AI reply text",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "wasmagent",
    "cards",
    "markdown",
    "d2",
    "parser"
  ],
  "wasmagent": {
    "tier": "tier-2",
    "stability": "stable"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WasmAgent/wasmagent-js.git",
    "directory": "packages/ui-cards"
  },
  "homepage": "https://github.com/WasmAgent/wasmagent-js/tree/main/packages/ui-cards#readme",
  "bugs": {
    "url": "https://github.com/WasmAgent/wasmagent-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "wasmagent contributors"
}
