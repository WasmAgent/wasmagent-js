{
  "name": "@agentkit-js/mastra-sandbox",
  "version": "0.1.0",
  "description": "Mastra sandbox provider backed by agentkit-js kernels — WASM isolation with no external infrastructure (alternative to Blaxel/E2B providers)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentkit-js/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mastra",
    "sandbox",
    "code-execution",
    "wasm",
    "agent",
    "agentkit"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telleroutlook/agentkit-js.git",
    "directory": "packages/mastra-sandbox"
  },
  "homepage": "https://github.com/telleroutlook/agentkit-js/tree/main/packages/mastra-sandbox#readme",
  "bugs": {
    "url": "https://github.com/telleroutlook/agentkit-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "agentkit-js contributors"
}
