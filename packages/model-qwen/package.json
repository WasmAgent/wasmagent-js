{
  "name": "@agentkit-js/model-qwen",
  "version": "0.1.0",
  "description": "Qwen (Alibaba DashScope) model adapter for agentkit-js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
