{
  "name": "@agentkit-js/a2a",
  "version": "0.1.0",
  "description": "A2A (Agent2Agent) adapter for agentkit-js — expose agents as A2A servers and call remote A2A agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentkit-js/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "a2a",
    "agent2agent",
    "agent",
    "interop",
    "agentkit"
  ],
  "license": "Apache-2.0"
}
