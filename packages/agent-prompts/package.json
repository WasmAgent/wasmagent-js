{
  "name": "@wasmagent/agent-prompts",
  "version": "1.0.0",
  "description": "Reusable system prompt templates for wasmagent — code/tool/framework prompts with D2 + Markdown card conventions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "wasmagent",
    "wasm",
    "agent",
    "portable",
    "sandbox",
    "executor",
    "ai",
    "llm",
    "typescript"
  ],
  "wasmagent": {
    "tier": "tier-2",
    "stability": "stable"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WasmAgent/wasmagent-js.git",
    "directory": "packages/agent-prompts"
  },
  "homepage": "https://github.com/WasmAgent/wasmagent-js/tree/main/packages/agent-prompts#readme",
  "bugs": {
    "url": "https://github.com/WasmAgent/wasmagent-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "wasmagent contributors"
}
