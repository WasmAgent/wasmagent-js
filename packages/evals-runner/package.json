{
  "name": "@agentkit-js/evals-runner",
  "version": "0.1.0",
  "description": "Evaluation runner for agentkit-js — multi-model multi-axis benchmark harness with paired statistics + Pareto report. Targets the gaps in evomerge-style single-axis evaluation: long-context recall, multi-turn memory, agent trajectory, latency, cost.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentkit-evals": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./stats": {
      "import": "./dist/stats/index.js",
      "types": "./dist/stats/index.d.ts"
    },
    "./suites": {
      "import": "./dist/suites/index.js",
      "types": "./dist/suites/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentkit-js/core": "workspace:*",
    "@agentkit-js/devtools": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agentkit",
    "evaluation",
    "benchmark",
    "model-evaluation",
    "pareto",
    "longmemeval",
    "paired-statistics"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telleroutlook/agentkit-js.git",
    "directory": "packages/evals-runner"
  },
  "homepage": "https://github.com/telleroutlook/agentkit-js/tree/main/packages/evals-runner#readme",
  "bugs": {
    "url": "https://github.com/telleroutlook/agentkit-js/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "agentkit-js contributors"
}
