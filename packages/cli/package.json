{
  "name": "@wasmagent/cli",
  "version": "1.3.9",
  "description": "CLI for wasmagent — mirrors smolagents' `smolagent` CLI (D6)",
  "type": "module",
  "bin": {
    "wasmagent": "./dist/index.js",
    "wasmagent-cli": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@wasmagent/core": "workspace:*",
    "@wasmagent/devtools": "workspace:*",
    "@wasmagent/evals-runner": "workspace:*",
    "zod": "^3.23.0",
    "@wasmagent/models": "workspace:*"
  },
  "peerDependencies": {
    "@wasmagent/model-local": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@wasmagent/model-local": {
      "optional": true
    }
  },
  "devDependencies": {
    "@wasmagent/model-local": "workspace:*",
    "@anthropic-ai/sdk": "^0.37.0",
    "typescript": "^5.7.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WasmAgent/wasmagent-js.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/WasmAgent/wasmagent-js/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/WasmAgent/wasmagent-js/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "wasmagent",
    "agent",
    "ai",
    "llm"
  ],
  "wasmagent": {
    "tier": "tier-1",
    "stability": "stable"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "wasmagent contributors"
}
