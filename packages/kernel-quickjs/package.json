{
  "name": "@wasmagent/kernel-quickjs",
  "version": "1.2.0",
  "description": "QuickJS-in-WASM kernel for wasmagent \u2014 safe for Cloudflare Workers and serverless environments that lack node:vm",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@wasmagent/core": "workspace:*"
  },
  "peerDependencies": {
    "quickjs-emscripten": ">=0.29.0",
    "quickjs-emscripten-core": ">=0.29.0",
    "@jitl/quickjs-wasmfile-release-sync": ">=0.29.0"
  },
  "peerDependenciesMeta": {
    "quickjs-emscripten-core": {
      "optional": true
    },
    "@jitl/quickjs-wasmfile-release-sync": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jitl/quickjs-wasmfile-release-sync": "0.32.0",
    "quickjs-emscripten": "0.32.0",
    "quickjs-emscripten-core": "0.32.0",
    "typescript": "^5.7.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WasmAgent/wasmagent-js.git",
    "directory": "packages/kernel-quickjs"
  },
  "homepage": "https://github.com/WasmAgent/wasmagent-js/tree/main/packages/kernel-quickjs#readme",
  "bugs": {
    "url": "https://github.com/WasmAgent/wasmagent-js/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "wasmagent",
    "agent",
    "ai",
    "llm"
  ],
  "wasmagent": {
    "tier": "tier-0",
    "stability": "stable"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "wasmagent contributors"
}
