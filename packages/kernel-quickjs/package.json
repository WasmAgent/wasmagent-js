{
  "name": "@agentkit-js/kernel-quickjs",
  "version": "0.2.0",
  "description": "QuickJS-in-WASM kernel for agentkit-js — safe for Cloudflare Workers and serverless environments that lack node:vm",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentkit-js/core": "workspace:*"
  },
  "peerDependencies": {
    "quickjs-emscripten": ">=0.29.0",
    "quickjs-emscripten-core": ">=0.29.0",
    "@jitl/quickjs-wasmfile-release-sync": ">=0.29.0"
  },
  "peerDependenciesMeta": {
    "quickjs-emscripten-core": {
      "optional": true
    },
    "@jitl/quickjs-wasmfile-release-sync": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jitl/quickjs-wasmfile-release-sync": "0.32.0",
    "quickjs-emscripten": "0.32.0",
    "quickjs-emscripten-core": "0.32.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telleroutlook/agentkit-js.git",
    "directory": "packages/kernel-quickjs"
  },
  "homepage": "https://github.com/telleroutlook/agentkit-js/tree/main/packages/kernel-quickjs#readme",
  "bugs": {
    "url": "https://github.com/telleroutlook/agentkit-js/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agentkit",
    "agent",
    "ai",
    "llm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "author": "agentkit-js contributors"
}
