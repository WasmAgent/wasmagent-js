{
  "name": "@agentkit-js/cloudflare-worker",
  "version": "0.1.0",
  "description": "Cloudflare Workers entry point for agentkit-js",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist .wrangler .turbo"
  },
  "dependencies": {
    "@agentkit-js/ag-ui": "workspace:*",
    "@agentkit-js/core": "workspace:*",
    "@agentkit-js/kernel-quickjs": "workspace:*",
    "@jitl/quickjs-wasmfile-release-sync": "0.32.0",
    "quickjs-emscripten-core": "0.32.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@cloudflare/workers-types": "^4.20241224.0",
    "@size-limit/preset-big-lib": "^12.1.0",
    "size-limit": "^12.1.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.93.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telleroutlook/agentkit-js.git",
    "directory": "packages/cloudflare-worker"
  },
  "homepage": "https://github.com/telleroutlook/agentkit-js/tree/main/packages/cloudflare-worker#readme",
  "bugs": {
    "url": "https://github.com/telleroutlook/agentkit-js/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agentkit",
